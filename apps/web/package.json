{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:vercel": "node ./scripts/write-env.mjs && ng build",
    "build:cloudflare": "node ./scripts/write-env.mjs && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint . --max-warnings 0 --ignore-pattern scripts/*",
    "lint:fix": "eslint . --fix --ignore-pattern scripts/*",
    "i18n:guard": "node ../../scripts/check-i18n-hardcoded-literals.mjs",
    "i18n:guard:strict": "node ../../scripts/check-i18n-hardcoded-literals.mjs --strict",
    "e2e": "playwright test",
    "e2e:auth": "playwright test e2e/auth.setup.ts --project=setup",
    "e2e:phase10": "playwright test e2e/phase-10-matrix.spec.ts"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "packageManager": "npm@10.9.0",
  "overrides": {
    "picomatch": "^4.0.4",
    "undici": "^7.24.0",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "@angular/cdk": "^21.2.11",
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@spartan-ng/brain": "^0.0.1-alpha.691",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@types/leaflet": "^1.9.21",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exifr": "^7.1.3",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "luxon": "^3.7.2",
    "pdfjs-dist": "^5.5.207",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.0.1",
    "@angular-eslint/eslint-plugin-template": "^21.0.1",
    "@angular-eslint/template-parser": "^21.0.1",
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@angular/platform-browser-dynamic": "^21.2.13",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.8"
  }
}
