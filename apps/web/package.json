{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:vercel": "node ./scripts/write-env.mjs && ng build",
    "build:cloudflare": "node ./scripts/write-env.mjs && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "i18n:guard": "node ../../scripts/check-i18n-hardcoded-literals.mjs",
    "i18n:guard:strict": "node ../../scripts/check-i18n-hardcoded-literals.mjs --strict"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/leaflet": "^1.9.21",
    "@types/qrcode": "^1.5.6",
    "exifr": "^7.1.3",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "pdfjs-dist": "^5.5.207",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.0",
    "@angular-eslint/eslint-plugin": "^21.0.1",
    "@angular-eslint/eslint-plugin-template": "^21.0.1",
    "@angular-eslint/template-parser": "^21.0.1",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.8"
  }
}
