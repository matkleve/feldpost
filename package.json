    "supabase:db:push": "node scripts/run-supabase-cli.mjs db push",
    "supabase:migration:list": "node scripts/run-supabase-cli.mjs migration list",
    "diagnose:geocoder": "node --experimental-strip-types scripts/diagnose-geocoder.ts",
    "geo:build-gemeinden": "node scripts/build-at-gemeinden-bev.mjs",
