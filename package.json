    "design-system:validate-registry": "node scripts/validate-design-system-registry.mjs",
    "design-system:guard-visual-behavior": "node scripts/guard-visual-behavior.mjs",
    "i18n:generate-language": "node scripts/generate-i18n-language.mjs",
    "i18n:validate-language": "node scripts/validate-i18n-language.mjs",
    "i18n:normalize-diacritics": "node scripts/normalize-i18n-diacritics.mjs",
    "i18n:validate-diacritics": "node scripts/validate-i18n-diacritics.mjs",
    "i18n:check": "node scripts/validate-i18n-diacritics.mjs",
    "i18n:normalize-de-umlauts": "node scripts/normalize-i18n-diacritics.mjs --lang=de",
    "i18n:validate-de-umlauts": "node scripts/validate-i18n-diacritics.mjs --lang=de",
    "i18n:guard": "node scripts/check-i18n-hardcoded-literals.mjs",
